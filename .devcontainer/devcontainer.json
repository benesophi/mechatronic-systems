{
  "name": "manipulator-sim",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--env=DISPLAY",
    "--volume=/tmp/.X11-unix:/tmp/.X11-unix:rw",
    "--net=host"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "eamodio.gitlens"
      ]
    }
  },
  "remoteUser": "vscode"
}